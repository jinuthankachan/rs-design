# --- Rust ---
/target/
**/*.rs.bk

# --- Tauri ---
/src-tauri/target/
/src-tauri/gen/

# --- Node / frontend build output (also covered by submodule's own .gitignore) ---
node_modules/
.next/
out/
dist/
.pnpm-store/

# --- Packaging / staging artifacts ---
/bundle/
# CP6 bundle staging: built by scripts/{fetch-node-runtime,build-daemon-bundle}.sh
# at package time (node binary ~101 M, pruned daemon ~71 M, content). Reproducible
# build output — never committed; CI runs the scripts before `tauri build`.
/src-tauri/bundle-resources/
*.deb
*.AppImage
*.rpm

# --- Local app data / runtime ---
.od/
.claude/
.agents/
.tmp/
.claudeignore

# --- OS / editor noise ---
.DS_Store
*.swp
*~
