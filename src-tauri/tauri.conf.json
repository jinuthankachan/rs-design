{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rs-design",
  "version": "0.1.0",
  "identifier": "io.rsdesign.app",
  "build": {
    "frontendDist": "./placeholder-ui"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "rs-design",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": ["icons/icon.png"],
    "category": "DeveloperTool",
    "shortDescription": "Open Design, native on Ubuntu",
    "longDescription": "A native Ubuntu desktop build of Open Design (Tauri + Rust).",
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0"]
      }
    }
  }
}
